# Database (SQLite for local dev; use postgresql://... in production)
DATABASE_URL="file:./dev.db"

# Auth — use a long random string in production
JWT_SECRET="change-me-in-production-min-32-chars-long-random"

# AI (server-side only — never VITE_ prefix)

# Preferred LLM provider for plan generation + chat coach.
# Options: "groq" | "nvidia" | "openrouter".
# If the preferred provider fails (rate-limit, outage, no credit), the server
# automatically falls back to the next available provider whose key is set.
LLM_PROVIDER="groq"

# Groq (https://console.groq.com/keys) — fastest, free tier 100k tokens/day
GROQ_API_KEY=""

# NVIDIA NIM (https://build.nvidia.com/) — used for RAG (embed + rerank) AND
# can serve as an LLM fallback. The same NVIDIA account credential works for
# all three; you can also set NVIDIA_LLM_API_KEY separately if you want to
# rotate it independently.
NVIDIA_EMBED_API_KEY=""
NVIDIA_RERANK_API_KEY=""
NVIDIA_LLM_API_KEY=""

# OpenRouter (https://openrouter.ai/keys) — many models, free tier on selected
# models like meta-llama/llama-3.3-70b-instruct:free. Optional; only used as
# fallback if both Groq and NVIDIA are unavailable.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_SITE_NAME="training-app"

# API port when running `npm run server:dev`
PORT=4000

# Comma-separated list of allowed origins for CORS in production.
# Example: CORS_ORIGINS="https://app.example.com,https://www.example.com"
# Leave empty in development (any origin reflected when NODE_ENV != production).
CORS_ORIGINS=""

# Client build talks to API (Vite dev proxies /api to PORT)
VITE_API_URL=""
